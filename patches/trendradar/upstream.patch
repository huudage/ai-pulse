+        if not self.comments_map or not report_data or not report_data.get("stats"):
+            return
+
+        name_to_id = {name: pid for pid, name in (id_to_name or {}).items()}
+        injected = 0
+        for stat in report_data["stats"]:
+            for title_data in stat.get("titles", []):
+                source_name = title_data.get("source_name", "")
+                title_text = title_data.get("title", "")
+                platform_id = name_to_id.get(source_name)
