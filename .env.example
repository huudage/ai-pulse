# ════════════════════════════════════════════════════════════
# AI Pulse — 可选 API key 配置
# ════════════════════════════════════════════════════════════
# 复制本文件为 .env，然后填入你想用的 key（不想用的留空即可）：
#
#   cp .env.example .env
#   nano .env
#
# install.sh / daily.sh / weekly.sh 会自动加载 .env，所以你不用 export
# 任何变量到 shell rc 文件里。
#
# 没填的 key 对应功能就跳过；不影响其他源工作。
# ════════════════════════════════════════════════════════════


# ───────────────────────────────────────────────────────────
# GitHub — 强烈推荐配置
# ───────────────────────────────────────────────────────────
# 不配：匿名 60 req/h，22 个 repo 全失败
# 配了：5000 req/h，所有 release / trending 都能抓
#
# 申请：https://github.com/settings/tokens
#       Generate new token (classic) → 不勾任何 scope 也行（只读 public）
#       → 生成的 ghp_xxx 字符串填这里
GITHUB_TOKEN=


# ───────────────────────────────────────────────────────────
# Web 搜索 — 二选一即可
# ───────────────────────────────────────────────────────────
# Brave Search：每月 2000 query 免费，无需信用卡
#   申请：https://brave.com/search/api/
#   生成的 key 填这里，多个用逗号分隔可轮询：
BRAVE_API_KEYS=
# 或
BRAVE_API_KEY=

# Tavily Search：每月 1000 query 免费，需要邮箱
#   申请：https://app.tavily.com/
TAVILY_API_KEY=

# 后端选择：auto（自动选已配置的）/ brave / tavily
WEB_SEARCH_BACKEND=auto


# ───────────────────────────────────────────────────────────
# Twitter / X — 推荐用 OpenCLI（零成本零鉴权，复用本机 Chrome 登录）
# ───────────────────────────────────────────────────────────
# X 在 2025 年关掉了所有公共 RSS 桥（rsshub / nitter 全死或被反爬）。
# 现在唯一可靠的免费方案是 OpenCLI —— 通过你已经登录的 Chrome 抓推文。
#
# 一次性配置（约 5 分钟）：
#   1. 装 opencli 二进制：https://github.com/jackwener/opencli/releases
#   2. 装 Chrome 扩展：chrome://extensions/ → Developer mode →
#                    Load unpacked → 选解压后的 extension/ 文件夹
#   3. 在那个 Chrome 里正常登录 X.com（用你自己账号）
#   4. 跑 `opencli doctor` 验证 — 应该看到三项全 [OK]
#
# 后续就是零干预：每次 weekly.sh 跑时自动通过 Chrome 抓 61 个 KOL 推文

TWITTER_API_BACKEND=opencli

# 并发数 — 默认值偏激进，并发过高容易触发超时。建议设为 3 以提高成功率。
OPENCLI_MAX_WORKERS=3

# OpenCLI 二进制路径（如果不在 PATH 里）
# OPENCLI_BIN=/path/to/opencli

# 跑完后自动关 OpenCLI 创建的 Twitter 标签页（默认 1）
OPENCLI_CLOSE_TABS_AFTER_RUN=1

# OpenCLI 1.8.0+ 要求每次 `browser <session> ...` 调用带 session 名。
# 复用同一 session 名能让 tab/state 跨调用保活；默认 follow-news。
# OPENCLI_BROWSER_SESSION=follow-news


# ───────────────────────────────────────────────────────────
# AI KOL 博客（可选补充，独立于 Twitter）
# ───────────────────────────────────────────────────────────
# 11 个深度博客（Simon Willison / Ethan Mollick / Nathan Lambert /
# Dwarkesh / Stratechery / Latent Space / Zvi Mowshowitz 等）。
# Twitter 抓的是实时推文（短反应、ratio），博客抓的是深度长文（深度观点）。
# 两者互补，建议都开。

ENABLE_KOL_BLOGS=true


# ───────────────────────────────────────────────────────────
# 付费 Twitter API（不推荐，仅在 OpenCLI 不可用时用）
# ───────────────────────────────────────────────────────────
# GETX_API_KEY=
# TWITTERAPI_IO_KEY=
# X_BEARER_TOKEN=


# ───────────────────────────────────────────────────────────
# Reddit OAuth（强烈推荐，零成本）
# ───────────────────────────────────────────────────────────
# 2023 起 Reddit 对匿名 JSON 请求全部 403。要让 r/LocalLLaMA、r/OpenAI 等
# 8 个 AI subreddit 拉到数据，必须配 client_credentials 凭据。
#
# 申请步骤（5 分钟，免费）：
#   1. 登录 reddit.com → 访问 https://www.reddit.com/prefs/apps
#   2. 拉到底，点 "are you a developer? create an app..."
#   3. 选 "script" 类型，name 随便，redirect uri 填 http://localhost
#   4. 创建后，client_id 在 app 名字下方（14 位字符串），client_secret 在 secret 字段
#
# 配置后，fetch-reddit.py 自动走 https://oauth.reddit.com，速率限 100 req/min/user。
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=


# ───────────────────────────────────────────────────────────
# 代理（按需）
# ───────────────────────────────────────────────────────────
# 如果你在国内访问 reddit.com / github.com / twitter 慢
# 在这里设代理，子进程会读取
# HTTPS_PROXY=http://127.0.0.1:7890
# HTTP_PROXY=http://127.0.0.1:7890


# ───────────────────────────────────────────────────────────
# Python 编码 — Windows 必须保留这两行
# ───────────────────────────────────────────────────────────
PYTHONUTF8=1
PYTHONIOENCODING=utf-8
